# ============================================================
# Git LFS candidates
# ============================================================
# DEVIANT2026_small.gif is 12 MB — migrate with:
#   git lfs track "*.gif"
#   git add .gitattributes
#   git rm --cached DEVIANT2026_small.gif
#   git add DEVIANT2026_small.gif
#   git commit -m "chore: migrate GIF to Git LFS"
