# ============================================================
# RainGod Comfy Studio — Environment Configuration
# Copy to .env and fill values. .env is gitignored.
# ============================================================

# ============================================================
# LOCAL STACK (Ollama — already deployed on Dell Latitude 5400)
# ============================================================
OLLAMA_HOST=http://localhost:11434

# Models available locally (pull with: ollama pull <name>)
# dolphin-llama3:8b   4.7GB   uncensored general/agent
# qwen3:4b            2.5GB   tools/structured JSON
# deepseek-r1:1.5b    1.1GB   reasoning
# moondream:1.8b      1.7GB   vision
# nomic-embed-text    274MB   embeddings

# ============================================================
# CLOUD — FREE TIER (all zero cost, no credit card required)
# ============================================================

# 1. Comfy Cloud — RTX Pro 6000, 96GB VRAM, 400 credits/month
#    Signup: https://comfy.org
COMFY_API_KEY=

# 2. Groq — LPU inference, 14,400 req/day free
#    Signup: https://console.groq.com
GROQ_API_KEY=

# 3. Google AI Studio — Gemini 2.0 Flash, free tier, multimodal
#    Signup: https://aistudio.google.com
GEMINI_API_KEY=

# 4. Suno — 50 songs/day free, full vocals + production
#    Signup: https://suno.com (enable API in settings)
SUNO_API_KEY=

# 5. OpenRouter — 300+ models, many free/:free tier
#    Signup: https://openrouter.ai
OPENROUTER_API_KEY=

# 6. HuggingFace — free Spaces GPU (AudioCraft, Demucs, etc.)
#    Signup: https://huggingface.co/settings/tokens
HF_TOKEN=

# 7. Replicate — $5 free credit on signup
#    Signup: https://replicate.com
REPLICATE_API_KEY=

# 8. Kaggle — 30hr GPU/week free (T4), for training
#    Signup: https://kaggle.com/settings → API token
KAGGLE_USERNAME=
KAGGLE_KEY=

# ============================================================
# BACKEND (FastAPI)
# ============================================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=1
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================================
# COMFYUI LOCAL (optional — only needed if using local GPU)
# ============================================================
COMFYUI_HOST=127.0.0.1
COMFYUI_PORT=8188

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=INFO
